    {
      "name": "177a7f3b",
      "displayName": "agg_daily_summary",
      "config": {
        "source": "binance_platform.gold.agg_daily_summary",
        "measures": [
          {
            "name": "count",
            "expr": "COUNT(*)",
            "comment": "Represents the total number of rows in the dataset. Use this measure to count all",
            "displayName": "Count"
          },
          {
            "displayName": "Avg Buy Pressure",
            "format": {
              "type": "percentage",
              "decimalPlaces": {
                "type": "exact",
                "places": 1.0
              }
            },
            "name": "avg_buy_pressure",
            "expr": "AVG(buy_pressure_ratio)",
            "comment": "Average buy pressure ratio - values above 0.5 indicate taker buy volume dominance"
          },
          {
            "displayName": "Avg VWAP",
            "format": {
              "type": "number",
              "decimalPlaces": {
                "type": "exact",
                "places": 2.0
              }
            },
            "name": "avg_vwap",
            "expr": "AVG(vwap)",
            "comment": "Average Volume Weighted Average Price per period"
          },
          {
            "displayName": "VWAP 7-Day Rolling Avg",
            "format": {
              "type": "number",
              "decimalPlaces": {
                "type": "exact",
                "places": 2.0
              }
            },
            "window": [
              {
                "order": "date",
                "range": "trailing 7 day",
                "semiadditive": "last"
              }
            ],
            "name": "rolling_vwap_7d",
            "expr": "MEASURE(avg_vwap)",
            "comment": "7-day trailing rolling average of VWAP - smooths out daily fluctuations"
          },
          {
            "displayName": "Avg Open",
            "format": {
              "type": "number",
              "decimalPlaces": {
                "type": "exact",
                "places": 2.0
              }
            },
            "name": "avg_open",
            "expr": "AVG(open)",
            "comment": "Average opening price"
          },
          {
            "displayName": "Avg High",
            "format": {
              "type": "number",
              "decimalPlaces": {
                "type": "exact",
                "places": 2.0
              }
            },
            "name": "avg_high",
            "expr": "AVG(high)",
            "comment": "Average daily high price"
          },
          {
            "displayName": "Avg Low",
            "format": {
              "type": "number",
              "decimalPlaces": {
                "type": "exact",
                "places": 2.0
              }
            },
            "name": "avg_low",
            "expr": "AVG(low)",
            "comment": "Average daily low price"
          },
          {
            "displayName": "Avg Close",
            "format": {
              "type": "number",
              "decimalPlaces": {
                "type": "exact",
                "places": 2.0
              }
            },
            "name": "avg_close",
            "expr": "AVG(close)",
            "comment": "Average closing price"
          },
          {
            "displayName": "Total Volume",
            "format": {
              "type": "number",
              "decimalPlaces": {
                "type": "exact",
                "places": 0.0
              },
              "abbreviation": "compact"
            },
            "name": "sum_volume",
            "expr": "SUM(total_base_volume)",
            "comment": "Sum of daily base asset volume"
          },
          {
            "displayName": "Avg Amplitude %",
            "format": {
              "type": "percentage",
              "decimalPlaces": {
                "type": "exact",
                "places": 2.0
              }
            },
            "name": "avg_amplitude",
            "expr": "AVG(amplitude_pct)",
            "comment": "Average daily price amplitude percentage - measures volatility"
          },
          {
            "displayName": "Total Trades",
            "format": {
              "type": "number",
              "decimalPlaces": {
                "type": "exact",
                "places": 0.0
              },
              "abbreviation": "compact"
            },
            "name": "total_trades_sum",
            "expr": "SUM(total_trades)",
            "comment": "Sum of daily trade count"
          }
        ],
        "version": "1.1",
        "dimensions": [
          {
            "name": "symbol",
            "expr": "symbols.symbol",
            "displayName": "Symbol"
          },
          {
            "name": "symbol_id",
            "expr": "source.symbol_id",
            "displayName": "Symbol Id"
          },
          {
            "name": "date",
            "expr": "source.date",
            "displayName": "Date"
          },
          {
            "name": "trade_quarter",
            "expr": "CONCAT(YEAR(date), '-Q', QUARTER(date))",
            "displayName": "Trade Quarter"
          },
          {
            "name": "open",
            "expr": "source.open",
            "displayName": "Open"
          },
          {
            "name": "high",
            "expr": "source.high",
            "displayName": "High"
          },
          {
            "name": "low",
            "expr": "source.low",
            "displayName": "Low"
          },
          {
            "name": "close",
            "expr": "source.close",
            "displayName": "Close"
          },
          {
            "name": "total_base_volume",
            "expr": "source.total_base_volume",
            "displayName": "Total Base Volume"
          },
          {
            "name": "total_trades",
            "expr": "source.total_trades",
            "displayName": "Total Trades"
          },
          {
            "name": "vwap",
            "expr": "source.vwap",
            "displayName": "Vwap"
          },
          {
            "name": "amplitude_pct",
            "expr": "source.amplitude_pct",
            "displayName": "Amplitude Pct"
          },
          {
            "name": "buy_pressure_ratio",
            "expr": "source.buy_pressure_ratio",
            "displayName": "Buy Pressure Ratio"
          }
        ],
        "joins": [
          {
            "name": "symbols",
            "source": "binance_platform.gold.dim_symbol",
            "on": "source.symbol_id = symbols.symbol_id"
          }
        ]
      }
    },
